// Module 6 — Ser vs Estar (A1)
// Drafted by content-builder for ux-builder to merge into src/data/modules.ts
// Song: "Estoy Aquí" by Shakira (Pop / Latin Pop primary — locked by team-lead
//   redirect on 2026-05-18 after curriculum-architect + song-validator consensus.
//   Reason: title IS the lesson — "Estoy Aquí" uses estar for both state ("I am
//   [longing]") and location ("here"). Concept match 10.0).
// Tappable preview vocab (NOT quizzed in isolation): estás, feliz, bien, aquí,
//   en casa, cansado/cansada — appear inline, marked with [tappable: ...].
// Words already seen in M1–M5 (safe to reuse freely): yo, tú, él, ella,
//   nosotros, ellos, de, con, sin, pero, también, y, hola, ¿cómo estás?, ¿qué?,
//   ¿quién?, ¿dónde?, numbers, alphabet.
// Output shape parallels module005Content.

export const module006Content = {
  id: 6,

  lessonTitle: 'Who You Are vs How You Are — Ser and Estar',

  conceptExplanation:
    "English has one verb for 'to be'. Spanish has two — and the split is the single most important thing you'll learn this week. Use ser for who someone is: their name, their nationality, their job, the things that don't change overnight. Use estar for how they are right now: feelings, mood, where they're standing. The same sentence — 'I am happy' — can mean two different things depending on which verb you reach for. Soy feliz says you're a happy person by nature. Estoy feliz says you're happy in this moment. Two verbs, two truths, one human.",

  preListeningContext: {
    intro:
      "Today's song is 'Estoy Aquí' by Shakira — and the title alone is the whole lesson. Estoy aquí means 'I am here', and Shakira uses estar twice in two words: estar for the state she's in (longing, waiting) and estar for where she is (here). Listen for how often the word estoy lands in the chorus. Every time she sings it, she's telling you about a moment — not an identity.",
    listenForWords: [
      { spanish: 'estoy', english: 'I am (state / location)' },
      { spanish: 'aquí', english: 'here' },
      { spanish: 'soy', english: 'I am (identity)' },
      { spanish: 'eres', english: 'you are (identity)' },
      { spanish: 'es', english: 'he / she / it is (identity)' },
    ],
    listeningGoal:
      "Count how many times Shakira sings estoy in the chorus. Then count the soy moments. Estoy is the verb of the moment; soy is the verb of identity. By the end of the song, you'll hear the difference without thinking about it.",
    verbSpotlight:
      "Six forms, two verbs. Yo + soy (ser) or estoy (estar). Tú + eres or estás. Él/ella + es or está. Same pronouns from Module 5, finally paired with their first real verbs. This is the moment Spanish starts feeling like sentences instead of a vocab list.",
    phraseChunkPreview: {
      spanish: 'Estoy bien, ¿y tú?',
      english: "I'm well, and you?",
      note: "The single most useful exchange a beginner can leave with. Recycles tú from Module 5 and y from Module 4 — and it's the textbook answer to ¿Cómo estás? from Module 3.",
    },
  },

  vocabulary: {
    core: [
      {
        spanish: 'soy',
        english: 'I am (identity)',
        pronunciationHint: 'One short syllable: "soy" — like the English word "soy" in soy sauce. Pure vowel, no drift. This is the form of ser the learner already saw in Module 5\'s phrase chunk (yo soy de México).',
        example: { spanish: 'soy de México', english: 'I am from Mexico' },
      },
      {
        spanish: 'eres',
        english: 'you are (identity, informal)',
        pronunciationHint: 'Two syllables: "EH-res". The rr is a single tap, not a roll — Module 1 pronunciation matters here. Use with friends, peers, family — anyone you\'d call tú.',
        example: { spanish: 'tú eres mi amigo', english: 'you are my friend' },
      },
      {
        spanish: 'es',
        english: 'he / she / it is (identity)',
        pronunciationHint: 'One syllable, soft: "es". Easy to miss in fast speech because it\'s so short — but you\'ll hear it in roughly every third Spanish sentence once your ear catches it.',
        example: { spanish: 'ella es doctora', english: 'she is a doctor' },
      },
      {
        spanish: 'estoy',
        english: 'I am (state / location)',
        pronunciationHint: 'Two syllables, stress on the second: "es-TOY". Same ending as soy, with an es- on the front. The single most useful word in this module — estoy bien, estoy aquí, estoy cansado.',
        example: { spanish: 'estoy aquí', english: 'I am here' },
      },
      {
        spanish: 'está',
        english: 'he / she / it is (state / location)',
        pronunciationHint: 'Two syllables, stress on the second: "es-TÁ". The accent on the á is grammatical — it tells you this is the verb (is), not esta without the accent (which means this, feminine). Module 2 accent rules doing real work.',
        example: { spanish: 'ella está en casa', english: 'she is at home' },
      },
    ],
    bonus: [
