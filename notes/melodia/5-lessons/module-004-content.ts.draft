export const module004Content = {
  id: 4,

  lessonTitle: 'The Glue Words That Hold Spanish Together',

  conceptExplanation:
    "Spanish has a small handful of tiny words — de, con, sin, pero, también — that do enormous work. They sit quietly between the bigger words, linking ideas, contrasts, and lists. Once your ear catches them, whole verses suddenly snap into focus. This is the module where Spanish stops being a list of words and starts becoming sentences.",

  preListeningContext: {
    intro:
      "Today's song is 'A Dios Le Pido' by Juanes — a Colombian prayer-anthem built almost entirely out of glue words. Listen for the small connectors stitching each line to the next: con (with), sin (without), de (of/from), y (and). These are the words you'll catch first, even before you understand the full lyric.",
    listenForWords: [
      { spanish: 'de', english: 'of / from' },
      { spanish: 'con', english: 'with' },
      { spanish: 'sin', english: 'without' },
      { spanish: 'pero', english: 'but' },
      { spanish: 'también', english: 'also / too' },
    ],
    listeningGoal:
      "Listen for con and sin in the chorus. Notice how each one points to something Juanes wants in his life — or wants to be free of.",
    glueWordSpotlight:
      "Want a second example? Vicente Fernández's 'El Rey' (a ranchera classic from Mexico) lines up con, sin, y, and pero inside a single famous verse — four glue words in one breath. That's how often you'll meet these words once you start listening.",
    phraseChunkPreview: {
      spanish: 'Café con leche, sin azúcar.',
      english: 'Coffee with milk, no sugar.',
      note: "Six words. Two of our connectors. One sentence you can order tomorrow morning.",
    },
  },

  vocabulary: {
    core: [
      {
        spanish: 'de',
        english: 'of / from',
        pronunciationHint: 'A soft "deh" — almost swallowed in fast speech.',
        example: { spanish: 'soy de Colombia', english: "I'm from Colombia" },
      },
      {
        spanish: 'con',
        english: 'with',
        pronunciationHint: 'Like English "cone" with the final E cut off.',
        example: { spanish: 'café con leche', english: 'coffee with milk' },
      },
      {
        spanish: 'sin',
        english: 'without',
        pronunciationHint: 'Like English "seen" but shorter and sharper.',
        example: { spanish: 'sin azúcar', english: 'without sugar' },
      },
      {
        spanish: 'pero',
        english: 'but',
        pronunciationHint: 'Tap the R once — soft, not rolled. Don\'t confuse with perro (dog), which has the trilled R.',
        example: { spanish: 'pero hablo inglés', english: 'but I speak English' },
      },
      {
        spanish: 'también',
        english: 'also / too',
        pronunciationHint: 'Stress on the final bién — the accent mark tells you where to land.',
        example: { spanish: 'yo también', english: 'me too' },
      },
    ],
    bonus: [
      {
        spanish: 'y',
        english: 'and',
        pronunciationHint: 'A single "ee" sound — the most-used word in Spanish.',
        example: { spanish: 'pan y agua', english: 'bread and water' },
      },
      {
        spanish: 'o',
        english: 'or',
        pronunciationHint: 'A pure "oh" — never the diphthong English speakers slip in.',
        example: { spanish: 'café o té', english: 'coffee or tea' },
      },
      {
        spanish: 'nunca',
        english: 'never',
